# Sonicverse Radio Streaming Stack — Configuration
#
# REQUIRED (minimal deployment):
#   - ICECAST_* — stream distribution
#   - HARBOR_* — studio input
#   - LETSENCRYPT_EMAIL — SSL certificate
#
# OPTIONAL (recommended for production):
#   - PUSHOVER_* — alert notifications
#   - POSTHOG_* — analytics
#   - APPWRITE_* — operator panel authentication
#
# Auto-generated during setup (./install.sh):
#   - ICECAST_RELAY_PASSWORD, ICECAST_SOURCE_PASSWORD, HARBOR_PASSWORD, etc.

# ============================================================
# Station identity (customize these)
# ============================================================
STATION_NAME=My Radio Station
STATION_LOCATION=Your Country
STATION_ADMIN_EMAIL=admin@example.com

# ============================================================
# Icecast — Stream distribution (REQUIRED)
# ============================================================
# Auto-generated during setup if .env doesn't exist
ICECAST_SOURCE_PASSWORD=changeme_source
ICECAST_RELAY_PASSWORD=changeme_relay
ICECAST_ADMIN_USER=admin
ICECAST_ADMIN_PASSWORD=changeme_admin

# Public hostname where listeners access streams
ICECAST_HOSTNAME=stream.example.com

# Max concurrent listeners across all mount points
ICECAST_MAX_LISTENERS=500

# ============================================================
# Liquidsoap harbor — Studio input (REQUIRED)
# ============================================================
# Auto-generated during setup if .env doesn't exist
HARBOR_PRIMARY_PORT=8010
HARBOR_FALLBACK_PORT=8011
HARBOR_PASSWORD=changeme_harbor

# Stream silence detection thresholds
SILENCE_THRESHOLD_DB=-40
SILENCE_DURATION=15

# ============================================================
# Let's Encrypt SSL (REQUIRED for HTTPS deployment)
# ============================================================
LETSENCRYPT_EMAIL=admin@example.com

# Set to 1 for staging (test certificates) during initial setup
# Change to 0 for production certificates once you've verified everything works
LETSENCRYPT_STAGING=0

# ============================================================
# Pushover alerts (OPTIONAL)
# ============================================================
# Leave both empty to disable alerts entirely
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# ============================================================
# Appwrite — Status panel authentication (OPTIONAL)
# ============================================================
# Required only if you want to use the interactive status panel
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
# Required when APPWRITE_PROJECT_ID is set (panel access is team-scoped).
APPWRITE_TEAM_ID=

# Status panel frontend URL (for CORS)
STATUS_PANEL_CORS_ORIGIN=https://status.example.com
STATUS_PANEL_HOST=127.0.0.1

# Comma-separated list of roles that can write/modify via panel
STATUS_PANEL_WRITE_ROLES=owner,admin

# Allow dangerous commands like "clear cache" in panel (0 = deny, 1 = allow)
STATUS_PANEL_ALLOW_RISKY_COMMANDS=0

# ============================================================
# PostHog — Streaming analytics (OPTIONAL)
# ============================================================
# Leave POSTHOG_API_KEY empty to disable analytics entirely
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# How often to poll Icecast for listener stats (seconds)
POSTHOG_POLL_INTERVAL=30
