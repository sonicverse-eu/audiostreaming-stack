# Station
STATION_NAME=My Radio Station
STATION_LOCATION=Your Country
STATION_ADMIN_EMAIL=admin@example.com

# Icecast
ICECAST_SOURCE_PASSWORD=changeme_source
ICECAST_RELAY_PASSWORD=changeme_relay
ICECAST_ADMIN_USER=admin
ICECAST_ADMIN_PASSWORD=changeme_admin
ICECAST_HOSTNAME=stream.example.com
ICECAST_MAX_LISTENERS=500

# Liquidsoap harbor (studio → liquidsoap)
HARBOR_PRIMARY_PORT=8010
HARBOR_FALLBACK_PORT=8011
HARBOR_PASSWORD=changeme_harbor

# Let's Encrypt
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_STAGING=0

# Pushover alerts
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
SILENCE_THRESHOLD_DB=-40
SILENCE_DURATION=15

# Appwrite (auth for status panel)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_TEAM_ID=

# Status panel
STATUS_PANEL_CORS_ORIGIN=https://status.example.com
STATUS_PANEL_WRITE_ROLES=owner,admin
STATUS_PANEL_ALLOW_RISKY_COMMANDS=0

# PostHog (optional — leave POSTHOG_API_KEY empty to disable analytics entirely)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
POSTHOG_POLL_INTERVAL=30
