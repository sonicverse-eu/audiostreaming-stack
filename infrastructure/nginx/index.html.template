<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>${STATION_NAME_ESC} — Stream on ${ICECAST_HOSTNAME}</title>
    <style>
        :root {
            --bg-color: #0f1117;
            --card-bg: #1a1d27;
            --border-color: #2a2e3d;
            --text-main: #e1e4ed;
            --text-muted: #8b90a0;
            --accent-start: #60a5fa; /* blue-400 */
            --accent-end: #a855f7; /* purple-500 */
            --font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        }
        
        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            font-family: var(--font-family);
            margin: 0;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            box-sizing: border-box;
            background-image: radial-gradient(circle at 50% -20%, rgba(96, 165, 250, 0.1), transparent 50%);
        }

        .container {
            background-color: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 3rem 2.5rem;
            width: 100%;
            max-width: 600px;
            box-shadow: 0 20px 40px -10px rgba(0,0,0,0.3);
            position: relative;
            overflow: hidden;
        }

        .container::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(to right, var(--accent-start), var(--accent-end));
        }

        .sonicverse-brand {
            background: linear-gradient(to right, var(--accent-start), var(--accent-end));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
            font-size: 0.9rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            margin-bottom: 1rem;
        }
        
        .header {
            text-align: center;
            margin-bottom: 2.5rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid var(--border-color);
        }

        .header h1 {
            margin: 0 0 0.5rem 0;
            font-size: 2.25rem;
            font-weight: 700;
        }

        .header p {
            color: var(--text-muted);
            margin: 0;
            font-size: 1rem;
        }

        .section-title {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.1em;
            color: var(--text-muted);
            margin-bottom: 1rem;
            font-weight: 600;
        }

        .endpoints-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
            margin-bottom: 2.5rem;
        }

        .endpoint-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background-color: rgba(255, 255, 255, 0.02);
            border: 1px solid var(--border-color);
            padding: 1.25rem 1.5rem;
            border-radius: 12px;
            text-decoration: none;
            color: var(--text-main);
            transition: all 0.2s ease;
        }

        .endpoint-card:hover {
            border-color: var(--accent-start);
            background-color: rgba(96, 165, 250, 0.04);
            transform: translateY(-2px);
        }

        .endpoint-info h3 {
            margin: 0 0 0.25rem 0;
            font-size: 1rem;
            font-weight: 600;
        }

        .endpoint-info p {
            margin: 0;
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .endpoint-card svg {
            color: var(--text-muted);
            transition: color 0.2s ease;
        }

        .endpoint-card:hover svg {
            color: var(--accent-start);
        }

        .contact-info {
            text-align: center;
            color: var(--text-muted);
            font-size: 0.9rem;
            background: rgba(255, 255, 255, 0.01);
            padding: 1.5rem;
            border-radius: 8px;
            border: 1px dashed var(--border-color);
        }

        .contact-info a {
            color: var(--accent-start);
            text-decoration: none;
            font-weight: 500;
            margin-left: 0.25rem;
            transition: color 0.2s ease;
        }

        .contact-info a:hover {
            color: var(--accent-end);
        }

        .footer {
            margin-top: 3rem;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.85rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .footer a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.2s ease;
        }

        .footer a:hover {
            color: var(--text-main);
            text-decoration: underline;
            text-underline-offset: 4px;
        }
        
        .footer-links {
            display: flex;
            justify-content: center;
            gap: 1.5rem;
            margin-top: 0.5rem;
        }

        .footer-links a {
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

        @media (max-width: 600px) {
            .container {
                padding: 2rem 1.5rem;
            }
            .header h1 {
                font-size: 1.75rem;
            }
            .endpoints-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="sonicverse-brand">Sonicverse</div>
            <h1>${STATION_NAME_ESC}</h1>
            <p>Streaming Audio Infrastructure at <span style="color: var(--text-main); font-weight: 500;">${ICECAST_HOSTNAME}</span></p>
        </div>

        <div class="section-title">Available Streams</div>
        <div class="endpoints-grid">
            <a href="/listen/stream-mp3-128" class="endpoint-card" target="_blank" rel="noopener noreferrer">
                <div class="endpoint-info">
                    <h3>MP3 (128kbps)</h3>
                    <p>Standard quality • Widely compatible</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            
            <a href="/listen/stream-mp3-320" class="endpoint-card" target="_blank" rel="noopener noreferrer">
                <div class="endpoint-info">
                    <h3>MP3 (320kbps)</h3>
                    <p>High quality • Maximum compatibility</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            
            <a href="/listen/stream-aac-128" class="endpoint-card" target="_blank" rel="noopener noreferrer">
                <div class="endpoint-info">
                    <h3>AAC (128kbps)</h3>
                    <p>Modern codec • Mobile optimized</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            
            <a href="/listen/stream-ogg-128" class="endpoint-card" target="_blank" rel="noopener noreferrer">
                <div class="endpoint-info">
                    <h3>Ogg Vorbis (128kbps)</h3>
                    <p>Open format • Linux friendly</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            
            <a href="/hls/live.m3u8" class="endpoint-card" target="_blank" rel="noopener noreferrer">
                <div class="endpoint-info">
                    <h3>HLS Stream</h3>
                    <p>Adaptive bitrate • Modern web players</p>
                </div>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
        </div>
        
        <div class="contact-info">
            Questions or inquiries? <br />
            Contact <a href="mailto:${STATION_ADMIN_EMAIL_ESC}">${STATION_ADMIN_EMAIL_ESC}</a>
        </div>
    </div>

    <div class="footer">
        <div>&copy; <script>document.write(new Date().getFullYear())</script> <span style="font-weight: 600; color: var(--text-main);">Sonicverse</span>. Released under the <a href="https://opensource.org/licenses/MIT" target="_blank" rel="noopener noreferrer">MIT License</a>.</div>
        <div class="footer-links">
            <a href="https://docs.sonicverse.eu" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                Documentation
            </a>
            <a href="https://github.com/sonicverse-eu/audiostreaming-stack" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.03c3.18-.3 6.5-1.5 6.5-7.1a5.8 5.8 0 0 0-1.6-4.03 5.5 5.5 0 0 0-.15-4.5s-1.3-.4-4.3 1.6a14.88 14.88 0 0 0-8 0c-3-2-4.3-1.6-4.3-1.6a5.5 5.5 0 0 0-.15 4.5A5.8 5.8 0 0 0 2 10.77c0 5.6 3.3 6.8 6.5 7.1a4.8 4.8 0 0 0-1 3.03v4"/><path d="M9 20c-5 1.5-5-2.5-7-3"/></svg>
                GitHub Repository
            </a>
        </div>
    </div>
</body>
</html>
